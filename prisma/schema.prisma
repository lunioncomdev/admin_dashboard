generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  admin
  user
}

enum ClientStatus {
  prospect
  actif
  inactif
}

enum ProjectStatus {
  nouveau
  en_cours
  en_pause
  termine
  annule
}

enum ActionPriority {
  basse
  moyenne
  haute
  urgente
}

enum ActionStatus {
  a_faire
  en_cours
  termine
  bloque
}

enum EventType {
  creation
  modification
  changement_statut
  commentaire
  document_ajout
  assignation
  note_manuelle
  suggestion_ia
}

enum NotificationChannel {
  in_app
  email
  both
}

enum AiSuggestionType {
  action_suggestion
  decision_aid
  draft_email
  client_summary
  anomaly_alert
  priority_ranking
}

enum AiSuggestionStatus {
  pending
  accepted
  dismissed
}

// ============================================================
// MODELS
// ============================================================

model User {
  id           String   @id @default(uuid())
  fullName     String   @map("full_name") @db.VarChar(100)
  email        String   @unique @db.VarChar(255)
  passwordHash String   @map("password_hash")
  role         UserRole @default(user)
  avatarUrl    String?  @map("avatar_url")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  clients               Client[]               @relation("CSMClients")
  ownedProjects         Project[]              @relation("ProjectOwner")
  assignedActions       Action[]               @relation("AssignedActions")
  createdActions        Action[]               @relation("CreatedActions")
  comments              Comment[]
  notifications         Notification[]
  notificationPrefs     NotificationPreference?
  aiSuggestions         AiSuggestion[]
  activityLogs          ActivityLog[]
  attachments           Attachment[]
  aiConfigUpdates       AiConfig[]

  @@map("users")
}

model Client {
  id          String       @id @default(uuid())
  companyName String       @map("company_name") @db.VarChar(255)
  address     String?
  sector      String?      @db.VarChar(100)
  startDate   DateTime?    @map("start_date") @db.Date
  csmId       String?      @map("csm_id")
  status      ClientStatus @default(prospect)
  notes       String?
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  // Relations
  csm          User?          @relation("CSMClients", fields: [csmId], references: [id])
  contacts     Contact[]
  projects     Project[]
  actions      Action[]
  attachments  Attachment[]
  activityLogs ActivityLog[]
  aiSuggestions AiSuggestion[]

  @@index([csmId])
  @@index([status])
  @@map("clients")
}

model Contact {
  id        String   @id @default(uuid())
  clientId  String   @map("client_id")
  fullName  String   @map("full_name") @db.VarChar(200)
  jobTitle  String?  @map("job_title") @db.VarChar(150)
  email     String   @db.VarChar(255)
  phone     String?  @db.VarChar(50)
  isPrimary Boolean  @default(false) @map("is_primary")
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  // Note: unicité du contact principal (is_primary=true) appliquée au niveau applicatif
  @@index([clientId])
  @@map("contacts")
}

model Project {
  id          String        @id @default(uuid())
  name        String        @db.VarChar(255)
  description String?
  clientId    String        @map("client_id")
  startDate   DateTime?     @map("start_date") @db.Date
  endDate     DateTime?     @map("end_date") @db.Date
  status      ProjectStatus @default(nouveau)
  ownerId     String?       @map("owner_id")
  budget      Decimal?      @db.Decimal(12, 2)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  // Relations
  client        Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  owner         User?          @relation("ProjectOwner", fields: [ownerId], references: [id])
  milestones    Milestone[]
  actions       Action[]
  attachments   Attachment[]
  activityLogs  ActivityLog[]
  aiSuggestions AiSuggestion[]

  @@index([clientId])
  @@index([ownerId])
  @@index([status])
  @@map("projects")
}

model Milestone {
  id          String    @id @default(uuid())
  projectId   String    @map("project_id")
  name        String    @db.VarChar(255)
  targetDate  DateTime? @map("target_date") @db.Date
  completed   Boolean   @default(false)
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("milestones")
}

model Action {
  id          String         @id @default(uuid())
  title       String         @db.VarChar(255)
  description String?
  clientId    String         @map("client_id")
  projectId   String         @map("project_id")
  assignedTo  String         @map("assigned_to")
  priority    ActionPriority @default(moyenne)
  status      ActionStatus   @default(a_faire)
  dueDate     DateTime       @map("due_date") @db.Date
  completedAt DateTime?      @map("completed_at")
  createdBy   String?        @map("created_by")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  // Relations
  client      Client       @relation(fields: [clientId], references: [id])
  project     Project      @relation(fields: [projectId], references: [id])
  assignee    User         @relation("AssignedActions", fields: [assignedTo], references: [id])
  creator     User?        @relation("CreatedActions", fields: [createdBy], references: [id])
  comments    Comment[]
  attachments Attachment[]
  activityLogs ActivityLog[]

  @@index([projectId])
  @@index([assignedTo])
  @@index([status])
  @@index([dueDate])
  @@index([clientId])
  @@map("actions")
}

model Comment {
  id        String   @id @default(uuid())
  actionId  String   @map("action_id")
  authorId  String   @map("author_id")
  content   String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  action Action @relation(fields: [actionId], references: [id], onDelete: Cascade)
  author User   @relation(fields: [authorId], references: [id])

  @@index([actionId])
  @@map("comments")
}

model Attachment {
  id        String   @id @default(uuid())
  filename  String   @db.VarChar(255)
  fileUrl   String   @map("file_url")
  fileSize  Int?     @map("file_size")
  mimeType  String?  @map("mime_type") @db.VarChar(100)
  clientId  String?  @map("client_id")
  projectId String?  @map("project_id")
  actionId  String?  @map("action_id")
  uploadedBy String? @map("uploaded_by")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  client   Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project  Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  action   Action?  @relation(fields: [actionId], references: [id], onDelete: Cascade)
  uploader User?    @relation(fields: [uploadedBy], references: [id])

  @@map("attachments")
}

model ActivityLog {
  id          String    @id @default(uuid())
  eventType   EventType @map("event_type")
  description String
  userId      String?   @map("user_id")
  clientId    String?   @map("client_id")
  projectId   String?   @map("project_id")
  actionId    String?   @map("action_id")
  metadata    Json?
  createdAt   DateTime  @default(now()) @map("created_at")

  // Relations
  user    User?    @relation(fields: [userId], references: [id])
  client  Client?  @relation(fields: [clientId], references: [id])
  project Project? @relation(fields: [projectId], references: [id])
  action  Action?  @relation(fields: [actionId], references: [id])

  @@index([clientId, createdAt(sort: Desc)])
  @@index([projectId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@index([eventType])
  @@map("activity_log")
}

model Notification {
  id        String              @id @default(uuid())
  userId    String              @map("user_id")
  title     String              @db.VarChar(255)
  message   String
  channel   NotificationChannel @default(in_app)
  isRead    Boolean             @default(false) @map("is_read")
  linkUrl   String?             @map("link_url")
  createdAt DateTime            @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id])

  @@index([userId, isRead, createdAt(sort: Desc)])
  @@map("notifications")
}

model NotificationPreference {
  id             String   @id @default(uuid())
  userId         String   @unique @map("user_id")
  reminderDays   Int      @default(3) @map("reminder_days")
  emailDigest    Boolean  @default(true) @map("email_digest")
  notifyComment  Boolean  @default(true) @map("notify_comment")
  notifyOverdue  Boolean  @default(true) @map("notify_overdue")
  notifyAssign   Boolean  @default(true) @map("notify_assign")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id])

  @@map("notification_preferences")
}

model AiSuggestion {
  id          String             @id @default(uuid())
  type        AiSuggestionType
  content     String
  contextData Json?              @map("context_data")
  modelUsed   String?            @map("model_used") @db.VarChar(50)
  tokensUsed  Int?               @map("tokens_used")
  clientId    String?            @map("client_id")
  projectId   String?            @map("project_id")
  requestedBy String             @map("requested_by")
  status      AiSuggestionStatus @default(pending)
  createdAt   DateTime           @default(now()) @map("created_at")

  // Relations
  client    Client?  @relation(fields: [clientId], references: [id])
  project   Project? @relation(fields: [projectId], references: [id])
  requester User     @relation(fields: [requestedBy], references: [id])

  @@index([clientId])
  @@index([requestedBy])
  @@map("ai_suggestions")
}

model AiConfig {
  id            String   @id @default(uuid())
  isEnabled     Boolean  @default(true) @map("is_enabled")
  modelName     String   @default("gpt-4o") @map("model_name") @db.VarChar(50)
  monthlyBudget Decimal  @default(50.00) @map("monthly_budget") @db.Decimal(8, 2)
  currentSpend  Decimal  @default(0.00) @map("current_spend") @db.Decimal(8, 2)
  resetDay      Int      @default(1) @map("reset_day")
  updatedBy     String?  @map("updated_by")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  updater User? @relation(fields: [updatedBy], references: [id])

  @@map("ai_config")
}
